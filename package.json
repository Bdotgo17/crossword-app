{
  "name": "crossword-app",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm --workspace frontend run dev\" \"npm --workspace backend run dev\"",
    "start": "npm --workspace backend run start",
    "build": "npm --workspaces run build"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}
